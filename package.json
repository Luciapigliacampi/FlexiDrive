{
  "name": "flexidrive-monorepo",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.13.0",
    "react-scripts": "5.0.1",
    "recharts": "^3.8.0",
    "speakeasy": "^2.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "front": "npm --prefix flexidrive-front run dev",
    "auth": "npm --prefix microservicios/auth-service run start",
    "envio": "npm --prefix microservicios/envio-service run start",
    "viajes": "npm --prefix microservicios/viajes-service run start",
    "ia": "npm --prefix microservicios/ia-route-service run start",
    "all": "concurrently -n FRONT,AUTH,ENVIO,VIAJES,IA -c blue,green,yellow,magenta,cyan \"npm run front\" \"npm run auth\" \"npm run envio\" \"npm run viajes\" \"npm run ia\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
